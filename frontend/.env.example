# ─── Database ───────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/pumpx?schema=public"

# ─── Session Encryption ────────────────────────────────
# Must be at least 32 characters. Generate with: openssl rand -hex 16
SESSION_SECRET="change-me-to-a-random-32-char-secret"

# ─── Blockchain ─────────────────────────────────────────
# "base" for production, "base-sepolia" for testnet
NEXT_PUBLIC_CHAIN="base-sepolia"
NEXT_PUBLIC_FACTORY_ADDRESS="0x3b4774D45De4e271f857cAa7830Ee283bD7Bf544"

# ─── WalletConnect ──────────────────────────────────────
NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID="your-walletconnect-project-id"

# ─── AI (RedPill / OpenAI-compatible) ──────────────────
REDPILL_API_KEY="your-redpill-api-key"

# ─── Stock Data ─────────────────────────────────────────
ALPHA_VANTAGE_API_KEY="your-alpha-vantage-key"
TWELVE_DATA_API_KEY="your-twelve-data-key"

# ─── Redis (optional, for production rate limiting) ─────
# REDIS_URL="redis://localhost:6379"

# ─── RPC Endpoints (optional overrides) ────────────────
# BASE_RPC_URL="https://mainnet.base.org"
# BASE_SEPOLIA_RPC_URL="https://sepolia.base.org"

# ─── Legacy (deprecated — kept for reference) ──────────
# NEXT_PUBLIC_TOKEN_ARBRITRUM=
# NEXT_PUBLIC_FACTORY_ARBRITRUM=
# NEXT_PUBLIC_TOKEN_BASE=
# NEXT_PUBLIC_FACTORY_BASE=
# NEXT_PUBLIC_SUPABASE_URL=
